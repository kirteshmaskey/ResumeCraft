# ═══════════════════════════════════════════════════════════════════════════
# ResumeCraft — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────────
# This name is served to the frontend via the /api/v1/config endpoint
APP_NAME=ResumeCraft
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development
ALLOWED_ORIGINS=["http://localhost:4200"]


# ── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/resume_craft
DB_ECHO=False
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Redis ────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20

# ── Security ─────────────────────────────────────────────────────────────
# Generate JWT secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-to-a-256-bit-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AI Configuration (Unified Standard) ──────────────────────────────────
# Provider: openai | azure | deepseek | grok | local
AI_PROVIDER=openai
AI_API_KEY=sk-your-openai-key
AI_MODEL=gpt-4o-mini
AI_ENDPOINT=https://api.openai.com/v1
AI_API_VERSION=

# --- Provider Examples ---

# OpenAI:
# AI_PROVIDER=openai
# AI_API_KEY=sk-...
# AI_MODEL=gpt-4o-mini
# AI_ENDPOINT=https://api.openai.com/v1

# Azure OpenAI:
# AI_PROVIDER=azure
# AI_API_KEY=your-azure-key
# AI_MODEL=your-deployment-name
# AI_ENDPOINT=https://your-resource.openai.azure.com/
# AI_API_VERSION=2024-02-01
